@page "/display"
@page "/display/{deviceId}"
@page "/play/{deviceSlug}"
@using Signage.Common
@using Signage.App.Services
@using MudBlazor
@inject SignageApiClient ApiClient
@rendermode InteractiveServer
@implements IDisposable

<div class="display-page">
    <MudAppBar Style="position: absolute; top: 0; left: 0; right: 0; z-index: 1000;" Elevation="2">
        <MudText Typo="Typo.h6" Class="mr-4">
            <MudIcon Icon="@Icons.Material.Filled.Tv" Class="mr-2" />
            電子看板播放端
        </MudText>
        <MudChip T="string" Icon="@Icons.Material.Filled.LocationOn" Text="@GetCenterLabel()" Color="Color.Info" Size="Size.Small" Class="mr-2" />
        <MudSpacer />
        <MudChip T="string" Icon="@Icons.Material.Filled.Info" Text="@GetStatusText()" Color="Color.Info" Size="Size.Small" />
    </MudAppBar>

    <div class="display-container">
        @if (_isLoading)
        {
            <div class="placeholder-large">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Info" />
                <p>載入已啟用版型中...</p>
            </div>
        }
        else if (_currentLayout != null)
        {
            <div class="playback-stage @GetStageClass(_currentLayout.ScreenOrientation)">
                <div class="playback-canvas @GetCanvasClass(_currentLayout.ScreenOrientation)">
                    @foreach (var region in GetActiveRegions(_currentLayout))
                    {
                        <div class="playback-region" style="@GetRegionStyle(region)">
                            @switch (region.ContentType)
                            {
                                case RegionContentType.Video:
                                    if (!string.IsNullOrWhiteSpace(region.MediaUrl))
                                    {
                                        <video class="region-media" autoplay muted loop playsinline src="@region.MediaUrl"></video>
                                    }
                                    else
                                    {
                                        <div class="region-empty"><MudIcon Icon="@Icons.Material.Filled.Movie" /><span>未設定影片</span></div>
                                    }
                                    break;
                                case RegionContentType.Image:
                                    if (!string.IsNullOrWhiteSpace(region.MediaUrl))
                                    {
                                        <img class="region-media" src="@region.MediaUrl" alt="region" />
                                    }
                                    else
                                    {
                                        <div class="region-empty"><MudIcon Icon="@Icons.Material.Filled.Image" /><span>未設定圖片</span></div>
                                    }
                                    break;
                                case RegionContentType.MarqueeText:
                                    <div class="region-marquee">
                                        <div class="region-marquee-track">@(string.IsNullOrWhiteSpace(region.TextContent) ? "跑馬燈文字" : region.TextContent)</div>
                                    </div>
                                    break;
                                case RegionContentType.Clock:
                                    <div class="region-clock">@_now.ToString("yyyy/MM/dd HH:mm:ss")</div>
                                    break;
                                default:
                                    <div class="region-empty"><span>空白區塊</span></div>
                                    break;
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="placeholder-large">
                <MudIcon Icon="@Icons.Material.Filled.NoPhotography" Size="Size.Large" Style="font-size: 120px;" />
                <p>目前中心沒有已啟用版型</p>
            </div>
        }
    </div>

    <div class="status-bar">
        <span>方向：@GetOrientationLabel(_currentLayout?.ScreenOrientation ?? ScreenOrientation.Landscape16x9) | 版型：@(_currentLayout?.Name ?? "未啟用") | 區塊：@(_currentLayout?.ZoneCount ?? 0) | @_now.ToString("HH:mm:ss")</span>
        <span class="connection-status">
            @if (_isConnected)
            {
                <span style="color: #22c55e;">◉ 已連接</span>
            }
            else
            {
                <span style="color: #ef4444;">◉ 離線（本地模式）</span>
            }
        </span>
    </div>
</div>

<style>
    .display-page {
        position: fixed;
        inset: 0;
        background: #020617;
        overflow: hidden;
    }

    .display-container {
        position: absolute;
        top: 64px;
        left: 0;
        right: 0;
        bottom: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        background:
            radial-gradient(circle at top left, rgba(56, 189, 248, 0.12), transparent 30%),
            radial-gradient(circle at bottom right, rgba(249, 115, 22, 0.12), transparent 32%),
            linear-gradient(180deg, #0f172a 0%, #020617 100%);
    }

    .playback-stage {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    .playback-canvas {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border-radius: 28px;
        border: 6px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 32px 90px rgba(0, 0, 0, 0.45);
        background: #111827;
    }

    .playback-canvas.canvas-landscape {
        width: min(100%, 84rem);
        aspect-ratio: 16 / 9;
    }

    .playback-canvas.canvas-portrait {
        height: min(100%, 52rem);
        aspect-ratio: 9 / 16;
    }

    .playback-region {
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .playback-region:last-child {
        border-bottom: none;
    }

    .region-media {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .region-empty {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.35);
        background: repeating-linear-gradient(
            -45deg,
            rgba(51, 65, 85, 0.7),
            rgba(51, 65, 85, 0.7) 10px,
            rgba(30, 41, 59, 0.85) 10px,
            rgba(30, 41, 59, 0.85) 20px
        );
    }

    .region-marquee {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: linear-gradient(90deg, rgba(2, 132, 199, 0.9) 0%, rgba(14, 165, 233, 0.75) 100%);
    }

    .region-marquee-track {
        white-space: nowrap;
        font-size: clamp(1rem, 3vh, 2.4rem);
        font-weight: 700;
        color: #fff;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
        padding: 0 1.5rem;
        animation: marquee-scroll 16s linear infinite;
    }

    .region-clock {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: clamp(1.4rem, 4vh, 3.2rem);
        font-weight: 800;
        letter-spacing: 0.08em;
        color: #e2e8f0;
        background: radial-gradient(circle at center, rgba(30, 64, 175, 0.55), rgba(15, 23, 42, 0.95));
        text-shadow: 0 2px 12px rgba(96, 165, 250, 0.6);
    }

    .placeholder-large {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        color: rgba(255, 255, 255, 0.45);
    }

    .placeholder-large p {
        font-size: 1.1rem;
    }

    .status-bar {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40px;
        background-color: rgba(15, 23, 42, 0.92);
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        color: #cbd5e1;
        font-size: 12px;
        z-index: 100;
    }

    .connection-status {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    @@keyframes marquee-scroll {
        0%   { transform: translateX(100vw); }
        100% { transform: translateX(-200%); }
    }
</style>

@code {
    [CascadingParameter]
    public string SelectedCenter { get; set; } = "";

    /// <summary>從 URL 路由參數取得的設備 ID</summary>
    [Parameter]
    public string? DeviceId { get; set; }

    /// <summary>從 /play/{slug} 取得的設備公開代碼</summary>
    [Parameter]
    public string? DeviceSlug { get; set; }

    /// <summary>查詢參數：遊客中心 ID</summary>
    [SupplyParameterFromQuery]
    public string? CenterId { get; set; }

    /// <summary>查詢參數：中心內的設備編號（1, 2, 3）</summary>
    [SupplyParameterFromQuery]
    public int? DeviceNumber { get; set; }

    private string _selectedCenterName = "";
    private SignagePage? _currentLayout;
    private bool _isConnected = true;
    private bool _isLoading;
    private DateTime _now = DateTime.Now;
    private System.Threading.Timer? _clockTimer;
    private System.Threading.Timer? _refreshTimer;
    private bool _isRefreshing;

    protected override async Task OnInitializedAsync()
    {
        _clockTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            _now = DateTime.Now;
            StateHasChanged();
        }), null, 0, 1000);

        // 週期刷新設備版型，讓 /play/{slug} 在設備端可自動更新內容。
        _refreshTimer = new System.Threading.Timer(_ => InvokeAsync(async () =>
        {
            await RefreshLayoutSilentlyAsync();
        }), null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));

        await LoadActiveLayoutAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_selectedCenterName == SelectedCenter)
            return;

        await LoadActiveLayoutAsync();
    }

    private async Task LoadActiveLayoutAsync(bool showLoading = true)
    {
        if (showLoading)
            _isLoading = true;

        _currentLayout = null;

        try
        {
            // 優先級 0: /play/{deviceSlug}
            if (!string.IsNullOrWhiteSpace(DeviceSlug))
            {
                _currentLayout = await ApiClient.GetPageByDeviceSlugAsync(DeviceSlug);
                if (_currentLayout != null)
                {
                    EnsureRegions(_currentLayout);
                    return;
                }
            }

            // 優先級 1: 如果有 DeviceId，直接查詢該設備的配置
            if (!string.IsNullOrWhiteSpace(DeviceId))
            {
                _currentLayout = await ApiClient.GetPageByDeviceAsync(DeviceId);
                if (_currentLayout != null)
                {
                    EnsureRegions(_currentLayout);
                    return;
                }
            }

            // 優先級 2: 如果有 CenterId + DeviceNumber，查詢該設備
            if (!string.IsNullOrWhiteSpace(CenterId) && DeviceNumber.HasValue && DeviceNumber > 0)
            {
                _currentLayout = await ApiClient.GetPageByDeviceNumberAsync(CenterId, DeviceNumber.Value);
                if (_currentLayout != null)
                {
                    EnsureRegions(_currentLayout);
                    return;
                }
            }

            // 優先級 3: 如果有 CenterId，取該中心的啟用版型
            if (!string.IsNullOrWhiteSpace(CenterId))
            {
                _currentLayout = await ApiClient.GetActivePageByCenterAsync(CenterId);
                if (_currentLayout != null)
                {
                    EnsureRegions(_currentLayout);
                    return;
                }
            }

            // 優先級 4: 使用級聯參數（來自瀏覽器選擇器）
            var centers = await ApiClient.GetAllVisitorCentersAsync();
            if (!centers.Any())
                return;

            var center = string.IsNullOrWhiteSpace(SelectedCenter)
                ? centers.First()
                : centers.FirstOrDefault(c => c.Name == SelectedCenter);

            if (center == null)
                return;

            _selectedCenterName = center.Name;

            // 優先級 4a: 取該中心的第一個已啟用設備的版型
            var activeDevice = center.Devices?.FirstOrDefault(d => d.IsActive && !string.IsNullOrWhiteSpace(d.AssignedPageId));
            if (activeDevice != null)
            {
                _currentLayout = await ApiClient.GetSignagePageAsync(activeDevice.AssignedPageId);
                if (_currentLayout != null)
                {
                    EnsureRegions(_currentLayout);
                    return;
                }
            }

            // 優先級 4b: 取該中心整體的啟用版型（向後相容）
            _currentLayout = await ApiClient.GetActivePageByCenterAsync(center.Id);
            if (_currentLayout != null)
            {
                EnsureRegions(_currentLayout);
                return;
            }

            // 優先級 4c: 取該中心的第一個版型（向後相容）
            var pages = await ApiClient.GetPagesByCenterAsync(center.Id);
            var fallback = pages.FirstOrDefault();
            if (fallback != null)
            {
                EnsureRegions(fallback);
                _currentLayout = fallback;
            }
        }
        finally
        {
            if (showLoading)
                _isLoading = false;
        }
    }

    private async Task RefreshLayoutSilentlyAsync()
    {
        if (_isRefreshing || _isLoading)
            return;

        _isRefreshing = true;
        try
        {
            await LoadActiveLayoutAsync(showLoading: false);
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private static void EnsureRegions(SignagePage page)
    {
        if (page.Regions == null || page.Regions.Count == 0)
        {
            page.ZoneCount = Math.Max(page.ZoneCount, 1);
            var pct = Math.Round(100d / page.ZoneCount, 2);
            page.Regions = Enumerable.Range(0, page.ZoneCount)
                .Select(i => new SignageRegion
                {
                    SortOrder = i,
                    HeightPercent = i == page.ZoneCount - 1 ? 100d - pct * (page.ZoneCount - 1) : pct,
                    ContentType = RegionContentType.Empty
                })
                .ToList();
        }
    }

    private static IEnumerable<SignageRegion> GetActiveRegions(SignagePage page)
    {
        return (page.Regions ?? Enumerable.Empty<SignageRegion>())
            .OrderBy(r => r.SortOrder)
            .Take(page.ZoneCount > 0 ? page.ZoneCount : 1);
    }

    private static string GetRegionStyle(SignageRegion region)
    {
        return $"height: {Math.Max(region.HeightPercent, 0):0.##}%;";
    }

    private string GetStatusText() =>
        $"中心: {(_selectedCenterName == "" ? "未選擇" : _selectedCenterName)}";

    private string GetCenterLabel() =>
        string.IsNullOrWhiteSpace(_selectedCenterName) ? "未選擇中心" : _selectedCenterName;

    private static string GetOrientationLabel(ScreenOrientation o) =>
        o == ScreenOrientation.Portrait9x16 ? "9:16 直式" : "16:9 橫式";

    private static string GetStageClass(ScreenOrientation o) =>
        o == ScreenOrientation.Portrait9x16 ? "stage-portrait" : "stage-landscape";

    private static string GetCanvasClass(ScreenOrientation o) =>
        o == ScreenOrientation.Portrait9x16 ? "canvas-portrait" : "canvas-landscape";

    public void Dispose()
    {
        _clockTimer?.Dispose();
        _refreshTimer?.Dispose();
    }
}

@page "/display"
@page "/display/{deviceId}"
@page "/play/{deviceSlug}"
@layout Layout.LoginLayout
@using Signage.Common
@using Signage.App.Services
@using MudBlazor
@inject SignageApiClient ApiClient
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IDisposable

<script type="module" src="@Assets["Components/Pages/Display.razor.js"]"></script>

<div class="display-page">
    <div class="display-container">
        @if (_isLoading)
        {
            <div class="placeholder-large">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Info" />
                <p>載入已啟用版型中...</p>
            </div>
        }
        else if (_currentLayout != null)
        {
            <div class="playback-stage @GetStageClass(_currentLayout.ScreenOrientation)">
                <div class="playback-canvas @GetCanvasClass(_currentLayout.ScreenOrientation)">
                    <div class="display-toolbar-drawer" tabindex="0" aria-label="聲音控制抽屜">
                        <div class="display-toolbar-handle" aria-hidden="true">
                            <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" />
                        </div>

                        <div class="display-toolbar-panel">
                            <button type="button" class="display-audio-button" @onclick="ToggleMuteAsync" aria-label="切換聲音">
                                <MudIcon Icon="@(_isMuted ? Icons.Material.Filled.VolumeOff : Icons.Material.Filled.VolumeUp)" />
                            </button>
                            <input type="range"
                                   class="display-volume-slider"
                                   min="0"
                                   max="100"
                                   step="1"
                                   value="@_volumePercent"
                                   @oninput="OnVolumeInput" />
                            <span class="display-volume-label">@_volumePercent%</span>
                        </div>
                    </div>

                    @foreach (var region in GetActiveRegions(_currentLayout))
                    {
                        <div class="playback-region" style="@GetRegionStyle(region)">
                            @switch (region.ContentType)
                            {
                                case RegionContentType.Video:
                                    if (!string.IsNullOrWhiteSpace(GetCurrentMediaUrl(region)))
                                    {
                                        <video @key="@GetRegionMediaKey(region)"
                                                 class="region-media signage-video"
                                               autoplay
                                                                                             muted="@_isMuted"
                                               playsinline
                                                 preload="auto"
                                               loop="@(GetRegionMediaUrls(region).Count <= 1)"
                                               src="@GetCurrentMediaUrl(region)"></video>
                                    }
                                    else
                                    {
                                        <div class="region-empty"><MudIcon Icon="@Icons.Material.Filled.Movie" /><span>未設定影片</span></div>
                                    }
                                    break;
                                case RegionContentType.Image:
                                    if (!string.IsNullOrWhiteSpace(GetCurrentMediaUrl(region)))
                                    {
                                        <img @key="@GetRegionMediaKey(region)" class="region-media" src="@GetCurrentMediaUrl(region)" alt="region" />
                                    }
                                    else
                                    {
                                        <div class="region-empty"><MudIcon Icon="@Icons.Material.Filled.Image" /><span>未設定圖片</span></div>
                                    }
                                    break;
                                case RegionContentType.MarqueeText:
                                    <div class="region-marquee">
                                        <div class="region-marquee-track">@(string.IsNullOrWhiteSpace(region.TextContent) ? "跑馬燈文字" : region.TextContent)</div>
                                    </div>
                                    break;
                                case RegionContentType.Clock:
                                    <div class="region-clock">@_now.ToString("yyyy/MM/dd HH:mm:ss")</div>
                                    break;
                                default:
                                    <div class="region-empty"><span>空白區塊</span></div>
                                    break;
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="placeholder-large">
                <MudIcon Icon="@Icons.Material.Filled.NoPhotography" Size="Size.Large" Style="font-size: 120px;" />
                <p>目前中心沒有已啟用版型</p>
            </div>
        }
    </div>
</div>

<style>
    .display-page {
        position: fixed;
        inset: 0;
        background: #020617;
        overflow: hidden;
    }

    .display-toolbar-drawer {
        --drawer-control-size: 2.2rem;
        --drawer-radius: 0.8rem;
        position: absolute;
        top: 0.85rem;
        right: 0.85rem;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        transform: translateX(calc(100% - var(--drawer-control-size)));
        transition: transform 0.25s ease;
    }

    .display-toolbar-drawer:hover,
    .display-toolbar-drawer:focus,
    .display-toolbar-drawer:focus-within {
        transform: translateX(0);
    }

    .display-toolbar-handle {
        flex: 0 0 var(--drawer-control-size);
        width: var(--drawer-control-size);
        height: var(--drawer-control-size);
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--drawer-radius) 0 0 var(--drawer-radius);
        background: rgba(15, 23, 42, 0.72);
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-right: none;
        color: #e2e8f0;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    }

    .display-toolbar-panel {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        height: var(--drawer-control-size);
        padding: 0 0.55rem;
        box-sizing: border-box;
        border-radius: 0 var(--drawer-radius) var(--drawer-radius) 0;
        background: rgba(15, 23, 42, 0.58);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-left: none;
        backdrop-filter: blur(10px);
        color: #e2e8f0;
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.22);
    }

    .display-audio-button {
        flex: 0 0 var(--drawer-control-size);
        width: var(--drawer-control-size);
        height: var(--drawer-control-size);
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        color: #f8fafc;
        padding: 0;
        cursor: pointer;
        font: inherit;
    }

    .display-audio-button:hover {
        background: rgba(255, 255, 255, 0.14);
    }

    .display-toolbar-handle .mud-icon-root,
    .display-audio-button .mud-icon-root {
        width: 1.2rem;
        height: 1.2rem;
        font-size: 1.2rem;
    }

    .display-volume-slider {
        width: 7.2rem;
        accent-color: #38bdf8;
        cursor: pointer;
    }

    .display-volume-label {
        min-width: 3rem;
        text-align: right;
        font-size: 0.88rem;
        color: #cbd5e1;
    }

    .display-container {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
            radial-gradient(circle at top left, rgba(56, 189, 248, 0.08), transparent 28%),
            radial-gradient(circle at bottom right, rgba(249, 115, 22, 0.08), transparent 28%),
            linear-gradient(180deg, #020617 0%, #020617 100%);
    }

    .playback-stage {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    .playback-canvas {
        position: relative;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #111827;
    }

    .playback-canvas.canvas-landscape {
        width: min(100vw, calc(100vh * 16 / 9));
        height: min(100vh, calc(100vw * 9 / 16));
        aspect-ratio: 16 / 9;
    }

    .playback-canvas.canvas-portrait {
        width: min(100vw, calc(100vh * 9 / 16));
        height: min(100vh, calc(100vw * 16 / 9));
        aspect-ratio: 9 / 16;
    }

    .playback-region {
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .playback-region:last-child {
        border-bottom: none;
    }

    .region-media {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .region-empty {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.35);
        background: repeating-linear-gradient(
            -45deg,
            rgba(51, 65, 85, 0.7),
            rgba(51, 65, 85, 0.7) 10px,
            rgba(30, 41, 59, 0.85) 10px,
            rgba(30, 41, 59, 0.85) 20px
        );
    }

    .region-marquee {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: linear-gradient(90deg, rgba(2, 132, 199, 0.9) 0%, rgba(14, 165, 233, 0.75) 100%);
    }

    .region-marquee-track {
        white-space: nowrap;
        font-size: clamp(1rem, 3vh, 2.4rem);
        font-weight: 700;
        color: #fff;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
        padding: 0 1.5rem;
        animation: marquee-scroll 16s linear infinite;
    }

    .region-clock {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: clamp(1.4rem, 4vh, 3.2rem);
        font-weight: 800;
        letter-spacing: 0.08em;
        color: #e2e8f0;
        background: radial-gradient(circle at center, rgba(30, 64, 175, 0.55), rgba(15, 23, 42, 0.95));
        text-shadow: 0 2px 12px rgba(96, 165, 250, 0.6);
    }

    .placeholder-large {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        color: rgba(255, 255, 255, 0.45);
    }

    .placeholder-large p {
        font-size: 1.1rem;
    }

    @@keyframes marquee-scroll {
        0%   { transform: translateX(100vw); }
        100% { transform: translateX(-200%); }
    }

    @@media (max-width: 768px) {
        .display-toolbar-drawer {
            --drawer-control-size: 1.9rem;
            top: 0.55rem;
            right: 0.55rem;
        }

        .display-toolbar-drawer {
            transform: translateX(calc(100% - var(--drawer-control-size)));
        }

        .display-volume-slider {
            width: 5.8rem;
        }
    }
</style>

@code {
    [CascadingParameter]
    public string SelectedCenter { get; set; } = "";

    /// <summary>從 URL 路由參數取得的設備 ID</summary>
    [Parameter]
    public string? DeviceId { get; set; }

    /// <summary>從 /play/{slug} 取得的設備公開代碼</summary>
    [Parameter]
    public string? DeviceSlug { get; set; }

    /// <summary>查詢參數：遊客中心 ID</summary>
    [SupplyParameterFromQuery]
    public string? CenterId { get; set; }

    /// <summary>查詢參數：中心內的設備編號（1, 2, 3）</summary>
    [SupplyParameterFromQuery]
    public int? DeviceNumber { get; set; }

    private string _selectedCenterName = "";
    private SignagePage? _currentLayout;
    private bool _isLoading;
    private bool _isMuted = true;
    private int _volumePercent = 80;
    private DateTime _now = DateTime.Now;
    private System.Threading.Timer? _clockTimer;
    private System.Threading.Timer? _refreshTimer;
    private bool _isRefreshing;
    private System.Threading.Timer? _rotationTimer;
    private readonly Dictionary<string, int> _rotationIndices = new();

    protected override async Task OnInitializedAsync()
    {
        _clockTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            _now = DateTime.Now;
            StateHasChanged();
        }), null, 0, 1000);

        // 週期刷新設備版型，讓 /play/{slug} 在設備端可自動更新內容。
        _refreshTimer = new System.Threading.Timer(_ => InvokeAsync(async () =>
        {
            await RefreshLayoutSilentlyAsync();
        }), null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));

        _rotationTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            AdvanceMediaRotation();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(8), TimeSpan.FromSeconds(8));

        await LoadActiveLayoutAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_selectedCenterName == SelectedCenter)
            return;

        await LoadActiveLayoutAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_currentLayout == null)
            return;

        try
        {
            await JS.InvokeVoidAsync("signageDisplay.ensureVideosPlaying", _isMuted, _volumePercent / 100d);
        }
        catch
        {
            // Ignore transient JS/runtime errors during display refresh.
        }
    }

    private async Task ToggleMuteAsync()
    {
        _isMuted = !_isMuted;

        if (!_isMuted && _volumePercent == 0)
            _volumePercent = 80;

        try
        {
            await JS.InvokeVoidAsync("signageDisplay.ensureVideosPlaying", _isMuted, _volumePercent / 100d);
        }
        catch
        {
            // Ignore transient JS/runtime errors during user interaction.
        }
    }

    private async Task OnVolumeInput(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var value))
            return;

        _volumePercent = Math.Clamp(value, 0, 100);
        _isMuted = _volumePercent == 0;

        try
        {
            await JS.InvokeVoidAsync("signageDisplay.ensureVideosPlaying", _isMuted, _volumePercent / 100d);
        }
        catch
        {
            // Ignore transient JS/runtime errors during user interaction.
        }
    }

    private async Task LoadActiveLayoutAsync(bool showLoading = true)
    {
        if (showLoading)
            _isLoading = true;

        SignagePage? resolvedLayout = null;

        try
        {
            // 優先級 0: /play/{deviceSlug}
            if (!string.IsNullOrWhiteSpace(DeviceSlug))
            {
                resolvedLayout = await ApiClient.GetPageByDeviceSlugAsync(DeviceSlug);
                if (resolvedLayout != null)
                {
                    EnsureRegions(resolvedLayout);
                    _currentLayout = resolvedLayout;
                    SyncRotationKeys(resolvedLayout);
                    return;
                }
            }

            // 優先級 1: 如果有 DeviceId，直接查詢該設備的配置
            if (!string.IsNullOrWhiteSpace(DeviceId))
            {
                resolvedLayout = await ApiClient.GetPageByDeviceAsync(DeviceId);
                if (resolvedLayout != null)
                {
                    EnsureRegions(resolvedLayout);
                    _currentLayout = resolvedLayout;
                    SyncRotationKeys(resolvedLayout);
                    return;
                }
            }

            // 優先級 2: 如果有 CenterId + DeviceNumber，查詢該設備
            if (!string.IsNullOrWhiteSpace(CenterId) && DeviceNumber.HasValue && DeviceNumber > 0)
            {
                resolvedLayout = await ApiClient.GetPageByDeviceNumberAsync(CenterId, DeviceNumber.Value);
                if (resolvedLayout != null)
                {
                    EnsureRegions(resolvedLayout);
                    _currentLayout = resolvedLayout;
                    SyncRotationKeys(resolvedLayout);
                    return;
                }
            }

            // 優先級 3: 如果有 CenterId，取該中心的啟用版型
            if (!string.IsNullOrWhiteSpace(CenterId))
            {
                resolvedLayout = await ApiClient.GetActivePageByCenterAsync(CenterId);
                if (resolvedLayout != null)
                {
                    EnsureRegions(resolvedLayout);
                    _currentLayout = resolvedLayout;
                    SyncRotationKeys(resolvedLayout);
                    return;
                }
            }

            // 優先級 4: 使用級聯參數（來自瀏覽器選擇器）
            var centers = await ApiClient.GetAllVisitorCentersAsync();
            if (!centers.Any())
                return;

            var center = string.IsNullOrWhiteSpace(SelectedCenter)
                ? centers.First()
                : centers.FirstOrDefault(c => c.Name == SelectedCenter);

            if (center == null)
                return;

            _selectedCenterName = center.Name;

            // 優先級 4a: 取該中心的第一個已啟用設備的版型
            var activeDevice = center.Devices?.FirstOrDefault(d => d.IsActive && !string.IsNullOrWhiteSpace(d.AssignedPageId));
            if (activeDevice != null)
            {
                resolvedLayout = await ApiClient.GetSignagePageAsync(activeDevice.AssignedPageId);
                if (resolvedLayout != null)
                {
                    EnsureRegions(resolvedLayout);
                    _currentLayout = resolvedLayout;
                    SyncRotationKeys(resolvedLayout);
                    return;
                }
            }

            // 優先級 4b: 取該中心整體的啟用版型（向後相容）
            resolvedLayout = await ApiClient.GetActivePageByCenterAsync(center.Id);
            if (resolvedLayout != null)
            {
                EnsureRegions(resolvedLayout);
                _currentLayout = resolvedLayout;
                SyncRotationKeys(resolvedLayout);
                return;
            }

            // 優先級 4c: 取該中心的第一個版型（向後相容）
            var pages = await ApiClient.GetPagesByCenterAsync(center.Id);
            var fallback = pages.FirstOrDefault();
            if (fallback != null)
            {
                EnsureRegions(fallback);
                _currentLayout = fallback;
                SyncRotationKeys(fallback);
                return;
            }

            if (showLoading)
                _currentLayout = null;
        }
        finally
        {
            if (showLoading)
                _isLoading = false;
        }
    }

    private async Task RefreshLayoutSilentlyAsync()
    {
        if (_isRefreshing || _isLoading)
            return;

        _isRefreshing = true;
        try
        {
            await LoadActiveLayoutAsync(showLoading: false);
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private static void EnsureRegions(SignagePage page)
    {
        if (page.Regions == null || page.Regions.Count == 0)
        {
            page.ZoneCount = Math.Max(page.ZoneCount, 1);
            var pct = Math.Round(100d / page.ZoneCount, 2);
            page.Regions = Enumerable.Range(0, page.ZoneCount)
                .Select(i => new SignageRegion
                {
                    SortOrder = i,
                    HeightPercent = i == page.ZoneCount - 1 ? 100d - pct * (page.ZoneCount - 1) : pct,
                    ContentType = RegionContentType.Empty
                })
                .ToList();
        }

        foreach (var region in page.Regions)
        {
            region.MediaUrls ??= new List<string>();
            region.MediaIds ??= new List<string>();

            if (region.MediaUrls.Count == 0 && !string.IsNullOrWhiteSpace(region.MediaUrl))
                region.MediaUrls.Add(region.MediaUrl);

            if (region.MediaIds.Count == 0 && !string.IsNullOrWhiteSpace(region.MediaId))
                region.MediaIds.Add(region.MediaId);

            region.MediaUrl = region.MediaUrls.FirstOrDefault() ?? region.MediaUrl;
            region.MediaId = region.MediaIds.FirstOrDefault() ?? region.MediaId;
        }
    }

    private void AdvanceMediaRotation()
    {
        if (_currentLayout == null)
            return;

        foreach (var region in GetActiveRegions(_currentLayout))
        {
            var urls = GetRegionMediaUrls(region);
            if (urls.Count <= 1)
                continue;

            var key = string.IsNullOrWhiteSpace(region.Id) ? $"region-{region.SortOrder}" : region.Id;
            var currentIndex = _rotationIndices.TryGetValue(key, out var value) ? value : 0;
            _rotationIndices[key] = (currentIndex + 1) % urls.Count;
        }
    }

    private void SyncRotationKeys(SignagePage page)
    {
        _rotationIndices.Clear();
        foreach (var region in GetActiveRegions(page))
        {
            var key = string.IsNullOrWhiteSpace(region.Id) ? $"region-{region.SortOrder}" : region.Id;
            _rotationIndices[key] = 0;
        }
    }

    private List<string> GetRegionMediaUrls(SignageRegion region)
    {
        region.MediaUrls ??= new List<string>();

        if (region.MediaUrls.Count == 0 && !string.IsNullOrWhiteSpace(region.MediaUrl))
            region.MediaUrls.Add(region.MediaUrl);

        return region.MediaUrls;
    }

    private string GetCurrentMediaUrl(SignageRegion region)
    {
        var urls = GetRegionMediaUrls(region);
        if (urls.Count == 0)
            return region.MediaUrl;

        var key = string.IsNullOrWhiteSpace(region.Id) ? $"region-{region.SortOrder}" : region.Id;
        var index = _rotationIndices.TryGetValue(key, out var value) ? value : 0;

        return urls[index % urls.Count];
    }

    private string GetRegionMediaKey(SignageRegion region)
    {
        var key = string.IsNullOrWhiteSpace(region.Id) ? $"region-{region.SortOrder}" : region.Id;
        var currentUrl = GetCurrentMediaUrl(region);
        var index = _rotationIndices.TryGetValue(key, out var value) ? value : 0;
        return $"{key}-{index}-{currentUrl}";
    }

    private static IEnumerable<SignageRegion> GetActiveRegions(SignagePage page)
    {
        return (page.Regions ?? Enumerable.Empty<SignageRegion>())
            .OrderBy(r => r.SortOrder)
            .Take(page.ZoneCount > 0 ? page.ZoneCount : 1);
    }

    private static string GetRegionStyle(SignageRegion region)
    {
        return $"height: {Math.Max(region.HeightPercent, 0):0.##}%;";
    }

    private static string GetStageClass(ScreenOrientation o) =>
        o == ScreenOrientation.Portrait9x16 ? "stage-portrait" : "stage-landscape";

    private static string GetCanvasClass(ScreenOrientation o) =>
        o == ScreenOrientation.Portrait9x16 ? "canvas-portrait" : "canvas-landscape";

    public void Dispose()
    {
        _clockTimer?.Dispose();
        _refreshTimer?.Dispose();
        _rotationTimer?.Dispose();
    }
}

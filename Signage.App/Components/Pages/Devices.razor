@page "/devices"
@using Signage.Common
@using Signage.App.Services
@using MudBlazor
@inject ISnackbar Snackbar
@inject SignageApiClient ApiClient
@inject NavigationManager Nav
@rendermode InteractiveServer

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    @if (_isBusy)
    {
        <MudPaper Class="pa-3 mb-4" Elevation="1">
            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-2" />
            <MudText Typo="Typo.caption">@_busyMessage</MudText>
        </MudPaper>
    }

    <MudGrid>
        <MudItem xs="12" lg="3">
            <MudPaper Class="pa-4 mb-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">遊客中心清單</MudText>

                <MudTextField @bind-Value="_newCenterName"
                              Label="中心名稱"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-2" />
                <MudTextField @bind-Value="_newCenterLocation"
                              Label="中心地點"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-2" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Secondary"
                           FullWidth="true"
                           Class="mb-3"
                           OnClick="CreateCenter"
                           Disabled="@_isBusy">
                    新建遊客中心
                </MudButton>

                @if (_centers.Count == 0)
                {
                    <MudText Typo="Typo.caption">尚無遊客中心資料</MudText>
                }
                else
                {
                    @foreach (var center in _centers)
                    {
                        <MudButton Variant="@(_selectedCenterId == center.Id ? Variant.Filled : Variant.Outlined)"
                                   Color="@(_selectedCenterId == center.Id ? Color.Primary : Color.Default)"
                                   FullWidth="true"
                                   Class="mb-2"
                                   OnClick="@(() => SelectCenter(center))"
                                   Disabled="@_isBusy">
                            @center.Name
                        </MudButton>
                    }
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="9">
            @if (string.IsNullOrWhiteSpace(_selectedCenterId))
            {
                <MudAlert Severity="Severity.Info">請先在左側選擇一個遊客中心。</MudAlert>
            }
            else
            {
                <MudPaper Class="pa-5 mb-4" Elevation="2">
                    <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-3">
                        中心 > 設備 層級管理
                    </MudText>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <MudChip T="string" Text="@($"中心：{_selectedCenterName}")" Color="Color.Primary" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="@($"設備數：{_deviceNodes.Count} / 3")" Color="Color.Info" Variant="Variant.Outlined" />
                        <MudChip T="string" Text="@($"版型數：{_pages.Count}")" Color="Color.Secondary" Variant="Variant.Outlined" />
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <MudTextField @bind-Value="_newDeviceName"
                                      Label="新增設備名稱"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="device-input" />
                        <MudTextField @bind-Value="_newDeviceIp"
                                      Label="IP（選填）"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="device-input" />
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="RegisterDevice"
                                   Disabled="@(_isBusy || _deviceNodes.Count >= 3)">
                            新增設備
                        </MudButton>
                    </div>
                    @if (_deviceNodes.Count >= 3)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-2">每個中心最多 3 台設備。</MudText>
                    }
                </MudPaper>

                @if (_deviceNodes.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning">此中心尚未建立設備，請先新增設備。</MudAlert>
                }
                else
                {
                    <MudGrid>
                        @foreach (var node in _deviceNodes.OrderBy(x => x.DeviceNumber))
                        {
                            <MudItem xs="12" lg="6">
                                <MudPaper Class="pa-4 device-card" Elevation="2">
                                    <div class="d-flex justify-space-between align-center mb-3">
                                        <MudText Typo="Typo.h6">設備 @node.DeviceNumber</MudText>
                                        @if (node.IsOnline)
                                        {
                                            <MudChip T="string" Text="在線" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" />
                                        }
                                        else
                                        {
                                            <MudChip T="string" Text="離線" Color="Color.Error" Variant="Variant.Filled" Size="Size.Small" />
                                        }
                                    </div>

                                    <MudTextField @bind-Value="node.DeviceName"
                                                  Label="設備名稱"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="mb-2" />

                                    <MudTextField @bind-Value="node.DeviceSlug"
                                                  Label="專屬網址代碼（slug）"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  HelperText="例如：hj-01，系統會自動正規化"
                                                  Class="mb-2" />

                                    <MudSelect T="string"
                                               Label="套用版型"
                                               Value="@node.AssignedPageId"
                                               ValueChanged="@(v => OnPageChanged(node, v))"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="mb-2">
                                        <MudSelectItem Value="@string.Empty">未套用</MudSelectItem>
                                        @foreach (var pageItem in _pages)
                                        {
                                            <MudSelectItem Value="@(pageItem.Id)">@pageItem.Name</MudSelectItem>
                                        }
                                    </MudSelect>

                                    <MudSelect T="ScreenOrientation"
                                               Label="設備方向"
                                               Value="@node.ScreenOrientation"
                                               ValueChanged="@(v => node.ScreenOrientation = v)"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Class="mb-2">
                                        <MudSelectItem Value="@ScreenOrientation.Landscape16x9">16:9 橫式</MudSelectItem>
                                        <MudSelectItem Value="@ScreenOrientation.Portrait9x16">9:16 直式</MudSelectItem>
                                    </MudSelect>

                                    <MudSwitch T="bool" Value="@node.IsActive" ValueChanged="@(v => node.IsActive = v)" Color="Color.Primary" Label="設備啟用" Class="mb-2" />

                                    <MudPaper Class="pa-2 play-url-box" Outlined="true">
                                        <MudText Typo="Typo.caption" Class="mb-1">專屬播送網址</MudText>
                                        <MudText Typo="Typo.body2">@BuildPlayUrl(node.DeviceSlug)</MudText>
                                    </MudPaper>

                                    <div class="d-flex justify-end mt-3 gap-2 flex-wrap">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Info"
                                                   OnClick="@(() => ToggleDeviceContentEditor(node))"
                                                   Disabled="@(_isBusy || string.IsNullOrWhiteSpace(node.AssignedPageId))">
                                            內容編輯
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Success"
                                                   OnClick="@(() => SaveDevice(node))"
                                                   Disabled="@_isBusy">
                                            儲存設備設定
                                        </MudButton>
                                    </div>

                                    @if (_editingDeviceNumber == node.DeviceNumber)
                                    {
                                        <MudDivider Class="my-3" />
                                        <MudText Typo="Typo.subtitle1" Class="mb-2">設備內容客製化（@node.DeviceName）</MudText>
                                        <MudText Typo="Typo.caption" Class="d-block mb-2">版型：@GetAssignedPageName(node.AssignedPageId)</MudText>

                                        @foreach (var region in GetEditingRegions(node.DeviceNumber))
                                        {
                                            <MudPaper Class="pa-3 mb-2" Outlined="true">
                                                <MudText Typo="Typo.subtitle2" Class="mb-2">@GetRegionDisplayName(region.SortOrder)</MudText>

                                                <MudSelect T="RegionContentType"
                                                           Label="區塊內容"
                                                           Value="@region.ContentType"
                                                           ValueChanged="@(value => region.ContentType = value)"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Class="mb-2">
                                                    <MudSelectItem Value="@RegionContentType.Empty">空白</MudSelectItem>
                                                    <MudSelectItem Value="@RegionContentType.Video">影片</MudSelectItem>
                                                    <MudSelectItem Value="@RegionContentType.Image">圖片</MudSelectItem>
                                                    <MudSelectItem Value="@RegionContentType.MarqueeText">文字</MudSelectItem>
                                                    <MudSelectItem Value="@RegionContentType.Clock">時間</MudSelectItem>
                                                </MudSelect>

                                                @if (region.ContentType == RegionContentType.MarqueeText)
                                                {
                                                    <MudTextField @bind-Value="region.TextContent"
                                                                  Label="文字內容"
                                                                  Variant="Variant.Filled"
                                                                  Lines="2"
                                                                  Margin="Margin.Dense" />
                                                }
                                                else if (region.ContentType == RegionContentType.Video || region.ContentType == RegionContentType.Image)
                                                {
                                                    <MudSelect T="string"
                                                               Label="從媒體庫選擇素材"
                                                               @bind-Value="_selectedMediaForAdd"
                                                               Variant="Variant.Outlined"
                                                               Margin="Margin.Dense"
                                                               Class="mb-2">
                                                        <MudSelectItem Value="@string.Empty">請選擇</MudSelectItem>
                                                        @foreach (var media in GetMediaOptions(region.ContentType))
                                                        {
                                                            <MudSelectItem Value="@media.Id">@media.Title</MudSelectItem>
                                                        }
                                                    </MudSelect>

                                                    <MudButton Variant="Variant.Outlined"
                                                               Color="Color.Primary"
                                                               Size="Size.Small"
                                                               OnClick="@(() => AddMediaToRegion(region))"
                                                               Disabled="@string.IsNullOrWhiteSpace(_selectedMediaForAdd)">
                                                        新增到輪播清單
                                                    </MudButton>

                                                    @if (region.MediaUrls.Any())
                                                    {
                                                        <MudList T="string" Dense="true" Class="mt-2">
                                                            @for (var index = 0; index < region.MediaUrls.Count; index++)
                                                            {
                                                                var removeIndex = index;
                                                                <MudListItem T="string">
                                                                    <MudText Typo="Typo.caption" Class="mr-2">@(removeIndex + 1).</MudText>
                                                                    <MudText Typo="Typo.caption" Class="flex-grow-1">@GetMediaDisplayName(region, removeIndex)</MudText>
                                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                                   Size="Size.Small"
                                                                                   Color="Color.Error"
                                                                                   OnClick="@(() => RemoveMediaFromRegion(region, removeIndex))" />
                                                                </MudListItem>
                                                            }
                                                        </MudList>
                                                    }
                                                }
                                            </MudPaper>
                                        }

                                        <div class="d-flex justify-end gap-2 mt-2">
                                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CloseDeviceContentEditor" Disabled="@_isBusy">取消</MudButton>
                                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => SaveDeviceContent(node))" Disabled="@_isBusy">儲存內容</MudButton>
                                        </div>
                                    }
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                }
            }
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .device-input {
        min-width: 220px;
    }

    .device-card {
        border: 1px solid rgba(30, 64, 175, 0.12);
        border-radius: 12px;
    }

    .play-url-box {
        background: rgba(30, 64, 175, 0.04);
        border-radius: 8px;
        word-break: break-all;
    }
</style>

@code {
    private string _currentCenterId = "";
    private string _selectedCenterId = "";
    private string _selectedCenterName = "";
    private List<VisitorCenter> _centers = new();
    private List<DeviceHierarchyNode> _deviceNodes = new();
    private List<SignagePage> _pages = new();
    private bool _isBusy;
    private string _busyMessage = "";
    private string _newDeviceName = "";
    private string _newDeviceIp = "";
    private string _newCenterName = "";
    private string _newCenterLocation = "";
    private List<MediaContent> _mediaLibrary = new();
    private int? _editingDeviceNumber;
    private string _selectedMediaForAdd = "";
    private Dictionary<int, List<DeviceRegionContent>> _deviceContentsDraft = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCentersAsync();
    }

    private async Task LoadCentersAsync()
    {
        await RunBusyActionAsync("讀取遊客中心中...", async () =>
        {
            _centers = await ApiClient.GetAllVisitorCentersAsync();
            if (!_centers.Any())
            {
                _selectedCenterId = "";
                _selectedCenterName = "";
                _currentCenterId = "";
                _deviceNodes = new();
                _pages = new();
                return;
            }

            if (string.IsNullOrWhiteSpace(_selectedCenterId) || _centers.All(c => c.Id != _selectedCenterId))
            {
                await SelectCenter(_centers.First());
                return;
            }

            _deviceNodes = await ApiClient.GetDeviceHierarchyByCenterAsync(_currentCenterId);
            _pages = await ApiClient.GetAllSignagePagesAsync();
            _mediaLibrary = await ApiClient.GetAllMediaAsync();
        }, "遊客中心資料已載入");
    }

    private async Task SelectCenter(VisitorCenter center)
    {
        _selectedCenterId = center.Id;
        _selectedCenterName = center.Name;
        _currentCenterId = center.Id;

        await RunBusyActionAsync($"切換到{center.Name}中...", async () =>
        {
            _deviceNodes = await ApiClient.GetDeviceHierarchyByCenterAsync(_currentCenterId);
            _pages = await ApiClient.GetAllSignagePagesAsync();
            _mediaLibrary = await ApiClient.GetAllMediaAsync();
            _editingDeviceNumber = null;
        }, $"已切換至 {center.Name}");
    }

    private async Task RegisterDevice()
    {
        if (string.IsNullOrWhiteSpace(_currentCenterId))
            return;

        if (string.IsNullOrWhiteSpace(_newDeviceName))
        {
            Snackbar.Add("請輸入設備名稱", Severity.Warning);
            return;
        }

        await RunBusyActionAsync("新增設備中...", async () =>
        {
            var result = await ApiClient.RegisterDeviceAsync(_currentCenterId, _newDeviceName, _newDeviceIp);
            if (result == null)
                throw new InvalidOperationException("新增設備失敗");

            _newDeviceName = "";
            _newDeviceIp = "";
            _deviceNodes = await ApiClient.GetDeviceHierarchyByCenterAsync(_currentCenterId);
        }, "設備新增成功");
    }

    private async Task CreateCenter()
    {
        if (string.IsNullOrWhiteSpace(_newCenterName))
        {
            Snackbar.Add("請輸入遊客中心名稱", Severity.Warning);
            return;
        }

        await RunBusyActionAsync("建立遊客中心中...", async () =>
        {
            var center = await ApiClient.CreateVisitorCenterAsync(_newCenterName, _newCenterLocation);
            if (center == null)
                throw new InvalidOperationException("新建遊客中心失敗");

            _newCenterName = "";
            _newCenterLocation = "";

            await LoadCentersAsync();
            await SelectCenter(center);
        }, "遊客中心已建立");
    }

    private async Task SaveDevice(DeviceHierarchyNode node)
    {
        if (string.IsNullOrWhiteSpace(_currentCenterId))
            return;

        await RunBusyActionAsync($"儲存設備 {node.DeviceNumber} 設定中...", async () =>
        {
            var ok = await ApiClient.UpdateDeviceConfigAsync(
                _currentCenterId,
                node.DeviceNumber,
                node.DeviceName,
                node.AssignedPageId,
                node.ScreenOrientation,
                node.IsActive,
                node.DeviceSlug);

            if (!ok)
                throw new InvalidOperationException("儲存失敗：請確認 slug 未重複，且版型/設備存在");

            _deviceNodes = await ApiClient.GetDeviceHierarchyByCenterAsync(_currentCenterId);
        }, "設備設定已儲存，播送網址內容已更新");
    }

    private void OnPageChanged(DeviceHierarchyNode node, string? pageId)
    {
        node.AssignedPageId = pageId ?? "";
        node.AssignedPageName = _pages.FirstOrDefault(p => p.Id == node.AssignedPageId)?.Name ?? "未套用";
    }

    private string BuildPlayUrl(string slug)
    {
        var normalized = string.IsNullOrWhiteSpace(slug) ? "device" : slug.Trim();
        return $"{Nav.BaseUri}play/{normalized}";
    }

    private async Task ToggleDeviceContentEditor(DeviceHierarchyNode node)
    {
        if (string.IsNullOrWhiteSpace(node.AssignedPageId))
        {
            Snackbar.Add("請先為此設備選擇版型後再編輯內容", Severity.Warning);
            return;
        }

        if (_editingDeviceNumber == node.DeviceNumber)
        {
            _editingDeviceNumber = null;
            return;
        }

        await RunBusyActionAsync($"載入設備 {node.DeviceNumber} 內容中...", async () =>
        {
            var page = await ApiClient.GetSignagePageAsync(node.AssignedPageId);
            if (page == null)
                throw new InvalidOperationException("找不到版型");

            var saved = await ApiClient.GetDeviceRegionContentsAsync(_currentCenterId, node.DeviceNumber);
            var drafts = new List<DeviceRegionContent>();

            for (var index = 0; index < page.ZoneCount; index++)
            {
                var existing = saved.FirstOrDefault(item => item.SortOrder == index);
                drafts.Add(new DeviceRegionContent
                {
                    SortOrder = index,
                    ContentType = existing?.ContentType ?? RegionContentType.Empty,
                    TextContent = existing?.TextContent ?? "",
                    MediaIds = existing?.MediaIds?.ToList() ?? new List<string>(),
                    MediaUrls = existing?.MediaUrls?.ToList() ?? new List<string>()
                });
            }

            _deviceContentsDraft[node.DeviceNumber] = drafts;
            _selectedMediaForAdd = "";
            _editingDeviceNumber = node.DeviceNumber;
        });
    }

    private void CloseDeviceContentEditor()
    {
        _editingDeviceNumber = null;
        _selectedMediaForAdd = "";
    }

    private List<DeviceRegionContent> GetEditingRegions(int deviceNumber)
    {
        if (_deviceContentsDraft.TryGetValue(deviceNumber, out var regions))
            return regions;

        return new List<DeviceRegionContent>();
    }

    private IEnumerable<MediaContent> GetMediaOptions(RegionContentType contentType)
    {
        var mediaType = contentType == RegionContentType.Video ? "Video" : "Image";
        return _mediaLibrary.Where(item => item.MediaType == mediaType).OrderBy(item => item.Title);
    }

    private void AddMediaToRegion(DeviceRegionContent region)
    {
        var media = _mediaLibrary.FirstOrDefault(item => item.Id == _selectedMediaForAdd);
        if (media == null)
            return;

        if (!region.MediaIds.Contains(media.Id, StringComparer.OrdinalIgnoreCase))
            region.MediaIds.Add(media.Id);

        if (!region.MediaUrls.Contains(media.Url, StringComparer.OrdinalIgnoreCase))
            region.MediaUrls.Add(media.Url);

        _selectedMediaForAdd = "";
    }

    private void RemoveMediaFromRegion(DeviceRegionContent region, int index)
    {
        if (index < 0 || index >= region.MediaUrls.Count)
            return;

        region.MediaUrls.RemoveAt(index);
        if (index < region.MediaIds.Count)
            region.MediaIds.RemoveAt(index);
    }

    private string GetMediaDisplayName(DeviceRegionContent region, int index)
    {
        var mediaId = region.MediaIds.ElementAtOrDefault(index);
        if (!string.IsNullOrWhiteSpace(mediaId))
        {
            var media = _mediaLibrary.FirstOrDefault(item => item.Id == mediaId);
            if (media != null)
                return media.Title;
        }

        return region.MediaUrls.ElementAtOrDefault(index) ?? "未命名素材";
    }

    private string GetAssignedPageName(string pageId)
    {
        return _pages.FirstOrDefault(item => item.Id == pageId)?.Name ?? "未套用";
    }

    private static string GetRegionDisplayName(int sortOrder)
    {
        return sortOrder switch
        {
            0 => "上區塊",
            1 => "中區塊",
            _ => "下區塊"
        };
    }

    private async Task SaveDeviceContent(DeviceHierarchyNode node)
    {
        if (!_deviceContentsDraft.TryGetValue(node.DeviceNumber, out var regionContents))
            return;

        await RunBusyActionAsync($"儲存設備 {node.DeviceNumber} 內容中...", async () =>
        {
            var ok = await ApiClient.UpdateDeviceRegionContentsAsync(_currentCenterId, node.DeviceNumber, regionContents);
            if (!ok)
                throw new InvalidOperationException("儲存設備內容失敗");

            _editingDeviceNumber = null;
            Snackbar.Add("設備內容已套用，播放端將依設備客製化內容顯示", Severity.Success);
        });
    }

    private async Task RunBusyActionAsync(string busyMessage, Func<Task> action, string? successMessage = null)
    {
        if (_isBusy)
            return;

        _isBusy = true;
        _busyMessage = busyMessage;
        StateHasChanged();

        try
        {
            await action();
            if (!string.IsNullOrWhiteSpace(successMessage))
            {
                Snackbar.Add(successMessage, Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
            _busyMessage = "";
            StateHasChanged();
        }
    }
}

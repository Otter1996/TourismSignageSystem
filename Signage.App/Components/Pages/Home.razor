@page "/"
@using Signage.Common
@using MudBlazor

@* ... HTML 標籤部分 ... *@
<MudText Typo="Typo.h5">【@SelectedCenter】版型設定</MudText>

@code {
    // 💡 修正點：必須定義在 @code 區塊內，編譯器才認得它
    [CascadingParameter] 
    public string SelectedCenter { get; set; } = "";

    private Dictionary<string, SignagePage> _centerConfigs = new();

    private SignagePage CurrentConfig
    {
        get
        {
            if (string.IsNullOrEmpty(SelectedCenter)) return new SignagePage();
            
            if (!_centerConfigs.ContainsKey(SelectedCenter))
            {
                _centerConfigs[SelectedCenter] = new SignagePage {
                    TopContent = $"★ 歡迎蒞臨 {SelectedCenter} ★",
                    MiddleContentUrl = "https://www.w3schools.com/html/mov_bbb.mp4",
                    BottomContentUrl = "https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&w=800&q=80"
                };
            }
            return _centerConfigs[SelectedCenter];
        }
    }
}
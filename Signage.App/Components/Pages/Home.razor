@page "/"
@using Signage.Common
@using Signage.App.Services
@using MudBlazor
@inject ISnackbar Snackbar
@inject SignageApiClient ApiClient
@rendermode InteractiveServer

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    @if (!string.IsNullOrWhiteSpace(_editorScopeLabel))
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            @(_editorScopeLabel)
        </MudAlert>
    }

    @if (_isBusy)
    {
        <MudPaper Class="pa-3 mb-4" Elevation="1">
            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-2" />
            <MudText Typo="Typo.caption">@_busyMessage</MudText>
        </MudPaper>
    }

    <MudGrid>
            <MudItem xs="12" lg="5">
                <MudPaper Class="pa-6" Elevation="4">
                    <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.SpaceDashboard" Class="mr-2" />
                        動態版型編輯器
                    </MudText>

                    @if (_isLoadingCenterData)
                    {
                        <MudProgressCircular Indeterminate="true" Color="Color.Info" Class="mb-3" />
                        <MudText Typo="Typo.caption">讀取版型庫與素材中...</MudText>
                    }
                    else
                    {
                        <MudSelect T="string"
                                   Label="選擇版型"
                                   Value="@_selectedPageId"
                                   ValueChanged="SelectPage"
                                   Variant="Variant.Outlined"
                                   Class="mb-4">
                            @foreach (var pageItem in _pages)
                            {
                                <MudSelectItem Value="@pageItem.Id">@pageItem.Name</MudSelectItem>
                            }
                        </MudSelect>

                        @if (!string.IsNullOrWhiteSpace(_selectedPageId))
                        {
                            var page = GetCurrentPage();

                            <MudTextField @bind-Value="page.Name" Label="版型名稱" Variant="Variant.Filled" Margin="Margin.Dense" Class="mb-3" />

                            <MudSelect T="ScreenOrientation" Label="螢幕方向" @bind-Value="page.ScreenOrientation" Variant="Variant.Outlined" Class="mb-4">
                                <MudSelectItem Value="@ScreenOrientation.Landscape16x9">16:9 橫式</MudSelectItem>
                                <MudSelectItem Value="@ScreenOrientation.Portrait9x16">9:16 直式</MudSelectItem>
                            </MudSelect>

                            <MudText Typo="Typo.subtitle2" Class="mb-2">公版快選</MudText>
                            <div class="preset-grid mb-4">
                                @foreach (var preset in _presets)
                                {
                                    <MudButton Variant="@(IsPresetActive(page, preset) ? Variant.Filled : Variant.Outlined)"
                                               Color="@(IsPresetActive(page, preset) ? Color.Primary : Color.Default)"
                                               OnClick="@(() => ApplyPreset(page, preset))"
                                               Disabled="@_isBusy">
                                        @preset.Label
                                    </MudButton>
                                }
                            </div>

                            <MudText Typo="Typo.subtitle2" Class="mb-2">區塊數量</MudText>
                            <div class="d-flex gap-2 mb-4 flex-wrap">
                                <MudButton Variant="@(page.ZoneCount == 1 ? Variant.Filled : Variant.Outlined)" Color="Color.Info" OnClick="@(() => SetZoneCount(page, 1))">單一區塊</MudButton>
                                <MudButton Variant="@(page.ZoneCount == 2 ? Variant.Filled : Variant.Outlined)" Color="Color.Info" OnClick="@(() => SetZoneCount(page, 2))">雙區塊</MudButton>
                                <MudButton Variant="@(page.ZoneCount == 3 ? Variant.Filled : Variant.Outlined)" Color="Color.Info" OnClick="@(() => SetZoneCount(page, 3))">三區塊</MudButton>
                            </div>

                            <MudText Typo="Typo.subtitle2" Class="mb-2">高度比例設定</MudText>
                            @foreach (var region in GetEditableRegions(page))
                            {
                                <MudPaper Class="pa-3 mb-3 region-editor-card" Outlined="true">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">@GetRegionDisplayName(region.SortOrder, page.ZoneCount)</MudText>

                                    <MudNumericField T="double"
                                                     Label="高度百分比"
                                                     Value="@region.HeightPercent"
                                                     ValueChanged="@(value => UpdateRegionHeight(page, region.SortOrder, value))"
                                                     Immediate="true"
                                                     Min="0"
                                                     Max="100"
                                                     Variant="Variant.Filled"
                                                     Margin="Margin.Dense"
                                                     Class="mb-3" />

                                    <MudAlert Severity="Severity.Info" Dense="true">
                                        這裡只設定版型結構（區塊與比例）。圖片、影片、文字、時間等內容請到設備管理頁進行每台設備客製化。
                                    </MudAlert>
                                </MudPaper>
                            }

                            <MudAlert Severity="@(IsRatioValid(page) ? Severity.Success : Severity.Error)" Dense="true" Class="mb-4">
                                區塊總和：@GetTotalPercentage(page).ToString("0.##")% @if (!IsRatioValid(page)) { <span>，必須等於 100%</span> }
                            </MudAlert>

                            <div class="d-flex gap-2 mb-4">
                                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveConfiguration" FullWidth="true" Disabled="@(!CanSave(page) || _isBusy)">
                                    <MudIcon Icon="@Icons.Material.Filled.Save" Class="mr-2" />儲存設定
                                </MudButton>
                            </div>

                            <MudDivider Class="my-4" />

                            <MudText Typo="Typo.subtitle2" Class="mb-2">版型清單</MudText>
                            @foreach (var pageItem in _pages)
                            {
                                <MudPaper Class="pa-2 mb-2" Outlined="true">
                                    <div class="d-flex align-center justify-space-between gap-2">
                                        <div>
                                            <MudText Typo="Typo.body2">@pageItem.Name</MudText>
                                            <MudText Typo="Typo.caption">@pageItem.ZoneCount 區塊 / @(pageItem.IsActive ? "已啟用" : "未啟用")</MudText>
                                        </div>
                                        <div class="d-flex gap-1">
                                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="@(() => SelectPage(pageItem.Id))" Disabled="@_isBusy" />
                                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeletePage(pageItem.Id))" Disabled="@_isBusy" />
                                        </div>
                                    </div>
                                </MudPaper>
                            }

                            <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true" Class="mt-2" OnClick="CreateNewPage" Disabled="@_isBusy">
                                <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />新建版型
                            </MudButton>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">尚無任何版型，請點擊下方按鈕建立第一個版型。</MudAlert>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="CreateNewPage" Disabled="@_isBusy">
                                <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />新建第一個版型
                            </MudButton>
                        }
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="7">
                <MudPaper Class="pa-6" Elevation="2">
                    @if (!string.IsNullOrWhiteSpace(_selectedPageId))
                    {
                        var page = GetCurrentPage();

                        <div class="d-flex align-center justify-space-between flex-wrap gap-2 mb-4">
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Tv" Class="mr-2" />
                                16:9 即時預覽
                            </MudText>
                            <MudChip T="string" Color="@(IsRatioValid(page) ? Color.Success : Color.Error)" Variant="Variant.Outlined" Text="@($"總和 {GetTotalPercentage(page):0.##}%")" />
                        </div>

                        <div class="designer-stage @GetStageClass(page.ScreenOrientation)">
                            <div class="design-canvas @GetCanvasClass(page.ScreenOrientation)">
                                @foreach (var region in GetEditableRegions(page))
                                {
                                    <div class="preview-region"
                                         style="@GetRegionStyle(region)">
                                        <div class="region-header">
                                            <span>@GetRegionDisplayName(region.SortOrder, page.ZoneCount)</span>
                                            <span>@region.HeightPercent.ToString("0.##")%</span>
                                        </div>

                                        <div class="region-placeholder">版型區塊（內容由設備個別設定）</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </MudPaper>
            </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .preset-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
        gap: 0.5rem;
    }

    .region-editor-card {
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.95) 0%, rgba(241, 245, 249, 0.92) 100%);
    }

    .drop-hint {
        padding: 0.8rem 1rem;
        border: 1px dashed rgba(14, 116, 144, 0.45);
        border-radius: 12px;
        color: #0f766e;
        background: rgba(240, 253, 250, 0.8);
        text-align: center;
        font-size: 0.9rem;
    }

    .media-palette {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
        gap: 0.75rem;
    }

    .media-tile {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem;
        border-radius: 14px;
        background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 100%);
        border: 1px solid rgba(59, 130, 246, 0.22);
        cursor: grab;
        user-select: none;
    }

    .media-title {
        font-weight: 700;
        color: #0f172a;
    }

    .media-type {
        font-size: 0.8rem;
        color: #475569;
    }

    .designer-stage {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 44rem;
        padding: 1rem;
        background:
            radial-gradient(circle at top left, rgba(15, 118, 110, 0.14), transparent 30%),
            radial-gradient(circle at bottom right, rgba(217, 119, 6, 0.14), transparent 28%),
            linear-gradient(135deg, #f8fafc 0%, #edf2f7 100%);
        border-radius: 20px;
    }

    .designer-stage.stage-portrait {
        min-height: 54rem;
    }

    .design-canvas {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #020617;
        border: 6px solid #0f172a;
        border-radius: 24px;
        box-shadow: 0 28px 70px rgba(15, 23, 42, 0.22);
    }

    .design-canvas.canvas-landscape {
        width: min(100%, 56rem);
        aspect-ratio: 16 / 9;
    }

    .design-canvas.canvas-portrait {
        width: min(100%, 22rem);
        aspect-ratio: 9 / 16;
    }

    .preview-region {
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.82) 0%, rgba(30, 41, 59, 0.92) 100%);
    }

    .preview-region:last-child {
        border-bottom: none;
    }

    .region-header {
        position: absolute;
        top: 0.6rem;
        left: 0.8rem;
        right: 0.8rem;
        z-index: 3;
        display: flex;
        justify-content: space-between;
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.85rem;
        font-weight: 700;
        text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
    }

    .region-media {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .region-placeholder,
    .region-clock,
    .region-marquee {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        text-align: center;
    }

    .region-placeholder {
        padding: 1rem;
        color: rgba(255, 255, 255, 0.78);
        background: repeating-linear-gradient(
            -45deg,
            rgba(51, 65, 85, 0.8),
            rgba(51, 65, 85, 0.8) 12px,
            rgba(30, 41, 59, 0.92) 12px,
            rgba(30, 41, 59, 0.92) 24px
        );
    }

    .region-marquee {
        overflow: hidden;
        background: linear-gradient(90deg, rgba(2, 132, 199, 0.92) 0%, rgba(14, 165, 233, 0.8) 100%);
    }

    .region-marquee-track {
        white-space: nowrap;
        font-size: clamp(1rem, 2vw, 1.8rem);
        font-weight: 700;
        padding: 0 1rem;
        animation: marquee-flow 14s linear infinite;
    }

    .region-clock {
        font-size: clamp(1.1rem, 2.6vw, 2.4rem);
        font-weight: 800;
        letter-spacing: 0.08em;
        background: radial-gradient(circle at center, rgba(30, 64, 175, 0.55), rgba(15, 23, 42, 0.95));
    }

    @@keyframes marquee-flow {
        0% { transform: translateX(60%); }
        100% { transform: translateX(-60%); }
    }
</style>

@code {
    private readonly LayoutPreset[] _presets =
    [
        new("33 / 33 / 33", [33, 33, 34]),
        new("50 / 50", [50, 50]),
        new("30 / 70", [30, 70]),
        new("20 / 60 / 20", [20, 60, 20]),
        new("100% 全螢幕", [100])
    ];

    [SupplyParameterFromQuery]
    public string? PageId { get; set; }

    [SupplyParameterFromQuery]
    public string? CenterId { get; set; }

    [SupplyParameterFromQuery]
    public int? DeviceNumber { get; set; }

    private List<SignagePage> _pages = new();
    private List<MediaContent> _mediaLibrary = new();
    private List<VisitorCenter> _centers = new();
    private string _selectedPageId = "";
    private string? _draggingMediaId;
    private bool _isBusy;
    private bool _isLoadingCenterData;
    private string _busyMessage = "";
    private string _editorScopeLabel = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadLayoutLibraryAsync();
    }

    protected override Task OnParametersSetAsync()
    {
        ApplyEditorScope();
        return Task.CompletedTask;
    }

    private async Task LoadLayoutLibraryAsync()
    {
        _pages.Clear();
        _mediaLibrary.Clear();
        _selectedPageId = "";

        _isLoadingCenterData = true;

        try
        {
            _pages = await ApiClient.GetAllSignagePagesAsync();
            _centers = await ApiClient.GetAllVisitorCentersAsync();
            _mediaLibrary = new();

            foreach (var page in _pages)
            {
                NormalizePage(page);
            }

            _selectedPageId = _pages.FirstOrDefault()?.Id ?? "";
            ApplyEditorScope();
        }
        finally
        {
            _isLoadingCenterData = false;
        }
    }

    private async Task<List<MediaContent>> LoadAllMediaLibraryAsync()
    {
        return await ApiClient.GetAllMediaAsync();
    }

    private SignagePage GetCurrentPage()
    {
        return _pages.FirstOrDefault(p => p.Id == _selectedPageId) ?? new SignagePage();
    }

    private Task SelectPage(string pageId)
    {
        _selectedPageId = pageId;
        return Task.CompletedTask;
    }

    private async Task CreateNewPage()
    {
        await RunBusyActionAsync("建立新版型中...", async () =>
        {
            var created = await ApiClient.CreateSignagePageAsync("", $"新版型 {_pages.Count + 1}", LayoutType.TripleVertical);
            if (created == null)
                throw new InvalidOperationException("建立版型失敗");

            NormalizePage(created);
            _pages.Add(created);
            _selectedPageId = created.Id;
        }, "已建立新版型");
    }

    private async Task DeletePage(string pageId)
    {
        await RunBusyActionAsync("刪除版型中...", async () =>
        {
            var ok = await ApiClient.DeleteSignagePageAsync(pageId);
            if (!ok)
                throw new InvalidOperationException("刪除失敗");

            _pages = _pages.Where(p => p.Id != pageId).ToList();
            if (_selectedPageId == pageId)
            {
                _selectedPageId = _pages.FirstOrDefault()?.Id ?? "";
            }
        }, "版型已刪除");
    }

    private async Task SaveConfiguration()
    {
        await RunBusyActionAsync("儲存設定中...", async () =>
        {
            var page = GetCurrentPage();
            if (!CanSave(page))
                throw new InvalidOperationException("區塊比例總和必須等於 100%");

            PreparePageForPersistence(page);
            var success = await ApiClient.UpdateSignagePageAsync(page.Id, page);
            if (!success)
                throw new InvalidOperationException("儲存失敗");
        }, "設定已儲存（SQLite）");
    }

    private void ApplyPreset(SignagePage page, LayoutPreset preset)
    {
        page.ZoneCount = preset.Ratios.Length;
        page.Regions = EnsureRegionCount(page.Regions, page.ZoneCount);

        for (var index = 0; index < preset.Ratios.Length; index++)
        {
            page.Regions[index].HeightPercent = preset.Ratios[index];
            page.Regions[index].SortOrder = index;
            page.Regions[index].Name = GetRegionDisplayName(index, page.ZoneCount);
        }

        SetDerivedLayout(page);
    }

    private bool IsPresetActive(SignagePage page, LayoutPreset preset)
    {
        var regions = GetEditableRegions(page).ToList();
        if (regions.Count != preset.Ratios.Length)
            return false;

        for (var index = 0; index < preset.Ratios.Length; index++)
        {
            if (Math.Abs(regions[index].HeightPercent - preset.Ratios[index]) > 0.01)
                return false;
        }

        return true;
    }

    private void SetZoneCount(SignagePage page, int zoneCount)
    {
        page.ZoneCount = Math.Clamp(zoneCount, 1, 3);
        page.Regions = EnsureRegionCount(page.Regions, page.ZoneCount);

        var equalSize = Math.Round(100d / page.ZoneCount, 2);
        var remaining = 100d;
        for (var index = 0; index < page.ZoneCount; index++)
        {
            var value = index == page.ZoneCount - 1 ? remaining : equalSize;
            page.Regions[index].HeightPercent = value;
            page.Regions[index].SortOrder = index;
            page.Regions[index].Name = GetRegionDisplayName(index, page.ZoneCount);
            remaining -= value;
        }

        SetDerivedLayout(page);
    }

    private void UpdateRegionHeight(SignagePage page, int sortOrder, double value)
    {
        var region = GetEditableRegions(page).FirstOrDefault(r => r.SortOrder == sortOrder);
        if (region == null)
            return;

        region.HeightPercent = Math.Clamp(Math.Round(value, 2), 0, 100);
    }

    private IEnumerable<SignageRegion> GetEditableRegions(SignagePage page)
    {
        page.Regions = EnsureRegionCount(page.Regions, page.ZoneCount);
        return page.Regions.OrderBy(region => region.SortOrder).Take(page.ZoneCount);
    }

    private double GetTotalPercentage(SignagePage page)
    {
        return GetEditableRegions(page).Sum(region => region.HeightPercent);
    }

    private bool IsRatioValid(SignagePage page)
    {
        return Math.Abs(GetTotalPercentage(page) - 100d) < 0.01;
    }

    private bool CanSave(SignagePage page)
    {
        return !string.IsNullOrWhiteSpace(page.Id) && IsRatioValid(page);
    }

    private void BeginMediaDrag(string mediaId)
    {
        _draggingMediaId = mediaId;
    }

    private void EndMediaDrag()
    {
        _draggingMediaId = null;
    }

    private void AssignDraggingMediaToRegion(SignageRegion region)
    {
        if (string.IsNullOrWhiteSpace(_draggingMediaId))
            return;

        var media = _mediaLibrary.FirstOrDefault(item => item.Id == _draggingMediaId);
        if (media == null)
            return;

        EnsureRegionMediaCollections(region);

        if ((media.MediaType == "Video" || media.MediaType == "Image") && !string.IsNullOrWhiteSpace(media.Url))
        {
            if (!region.MediaIds.Contains(media.Id, StringComparer.OrdinalIgnoreCase))
                region.MediaIds.Add(media.Id);

            if (!region.MediaUrls.Contains(media.Url, StringComparer.OrdinalIgnoreCase))
                region.MediaUrls.Add(media.Url);

            region.MediaId = region.MediaIds.FirstOrDefault() ?? media.Id;
            region.MediaUrl = region.MediaUrls.FirstOrDefault() ?? media.Url;
        }

        region.TextContent = media.MediaType == "Text" || media.MediaType == "Link"
            ? media.Title
            : region.TextContent;

        region.ContentType = media.MediaType switch
        {
            "Video" => RegionContentType.Video,
            "Image" => RegionContentType.Image,
            "Text" => RegionContentType.MarqueeText,
            "Link" => RegionContentType.MarqueeText,
            _ => region.ContentType
        };

        _draggingMediaId = null;
    }

    private string GetRegionMediaSummary(SignageRegion region)
    {
        EnsureRegionMediaCollections(region);

        if (region.MediaUrls.Count > 0)
            return $"已綁定 {region.MediaUrls.Count} 筆素材";

        if (!string.IsNullOrWhiteSpace(region.MediaId))
        {
            var media = _mediaLibrary.FirstOrDefault(item => item.Id == region.MediaId);
            if (media != null)
                return media.Title;
        }

        return string.IsNullOrWhiteSpace(region.MediaUrl) ? "尚未綁定素材" : region.MediaUrl;
    }

    private void NormalizePage(SignagePage page)
    {
        page.ZoneCount = Math.Clamp(page.ZoneCount <= 0 ? page.Regions.Count : page.ZoneCount, 1, 3);
        page.Regions = EnsureRegionCount(page.Regions, page.ZoneCount);
        foreach (var region in page.Regions)
        {
            EnsureRegionMediaCollections(region);
        }
        SetDerivedLayout(page);
    }

    private void PreparePageForPersistence(SignagePage page)
    {
        NormalizePage(page);
        foreach (var region in page.Regions)
        {
            region.ContentType = RegionContentType.Empty;
            region.TextContent = "";
            region.MediaId = "";
            region.MediaUrl = "";
            region.MediaIds = new List<string>();
            region.MediaUrls = new List<string>();
        }
        SyncLegacyFieldsFromRegions(page);
        page.LastModified = DateTime.Now;
    }

    private static List<SignageRegion> EnsureRegionCount(List<SignageRegion>? regions, int zoneCount)
    {
        var current = (regions ?? new List<SignageRegion>())
            .OrderBy(region => region.SortOrder)
            .Take(3)
            .ToList();

        for (var index = current.Count; index < zoneCount; index++)
        {
            current.Add(new SignageRegion
            {
                SortOrder = index,
                Name = GetRegionDisplayName(index, zoneCount),
                HeightPercent = zoneCount == 1 ? 100 : Math.Round(100d / zoneCount, 2),
                ContentType = RegionContentType.Empty
            });
        }

        return current
            .Take(zoneCount)
            .Select((region, index) =>
            {
                region.SortOrder = index;
                region.Name = GetRegionDisplayName(index, zoneCount);
                return region;
            })
            .ToList();
    }

    private void SyncLegacyFieldsFromRegions(SignagePage page)
    {
        page.TopContent = "";
        page.MiddleContentUrl = "";
        page.BottomContentUrl = "";
        page.LeftContent = "";
        page.RightContent = "";
    }

    private void EnsureRegionMediaCollections(SignageRegion region)
    {
        region.MediaIds ??= new List<string>();
        region.MediaUrls ??= new List<string>();

        if (region.MediaUrls.Count == 0 && !string.IsNullOrWhiteSpace(region.MediaUrl))
            region.MediaUrls.Add(region.MediaUrl);

        if (region.MediaIds.Count == 0 && !string.IsNullOrWhiteSpace(region.MediaId))
            region.MediaIds.Add(region.MediaId);

        region.MediaId = region.MediaIds.FirstOrDefault() ?? "";
        region.MediaUrl = region.MediaUrls.FirstOrDefault() ?? "";
    }

    private List<string> GetRegionMediaUrls(SignageRegion region)
    {
        EnsureRegionMediaCollections(region);
        return region.MediaUrls;
    }

    private string GetRegionPrimaryMediaUrl(SignageRegion region)
    {
        EnsureRegionMediaCollections(region);
        return region.MediaUrls.FirstOrDefault() ?? region.MediaUrl;
    }

    private string GetRegionMediaDisplayName(SignageRegion region, int index)
    {
        EnsureRegionMediaCollections(region);

        var mediaId = region.MediaIds.ElementAtOrDefault(index);
        if (!string.IsNullOrWhiteSpace(mediaId))
        {
            var media = _mediaLibrary.FirstOrDefault(item => item.Id == mediaId);
            if (media != null)
                return media.Title;
        }

        return region.MediaUrls.ElementAtOrDefault(index) ?? "未命名素材";
    }

    private void RemoveRegionMedia(SignageRegion region, int index)
    {
        EnsureRegionMediaCollections(region);

        if (index < 0 || index >= region.MediaUrls.Count)
            return;

        region.MediaUrls.RemoveAt(index);
        if (index < region.MediaIds.Count)
            region.MediaIds.RemoveAt(index);

        region.MediaId = region.MediaIds.FirstOrDefault() ?? "";
        region.MediaUrl = region.MediaUrls.FirstOrDefault() ?? "";
    }

    private void ClearRegionMedia(SignageRegion region)
    {
        region.MediaIds = new List<string>();
        region.MediaUrls = new List<string>();
        region.MediaId = "";
        region.MediaUrl = "";
    }

    private void ApplyEditorScope()
    {
        var scopeParts = new List<string>();

        if (!string.IsNullOrWhiteSpace(CenterId))
        {
            var center = _centers.FirstOrDefault(item => item.Id == CenterId);
            scopeParts.Add($"中心：{center?.Name ?? CenterId}");
        }

        if (DeviceNumber.HasValue && DeviceNumber.Value > 0)
        {
            scopeParts.Add($"設備：{DeviceNumber.Value}");
        }

        if (!string.IsNullOrWhiteSpace(PageId))
        {
            var matchedPage = _pages.FirstOrDefault(item => item.Id == PageId);
            if (matchedPage != null)
            {
                _selectedPageId = matchedPage.Id;
                scopeParts.Add($"版型：{matchedPage.Name}");
            }
        }

        _editorScopeLabel = scopeParts.Count > 0
            ? $"目前編輯範圍：{string.Join(" / ", scopeParts)}"
            : "";
    }

    private static void SetDerivedLayout(SignagePage page)
    {
        page.Layout = page.ZoneCount switch
        {
            1 => LayoutType.SingleFull,
            2 => LayoutType.LType,
            _ => LayoutType.TripleVertical
        };
    }

    private static string GetRegionStyle(SignageRegion region)
    {
        return $"height: {Math.Max(region.HeightPercent, 0)}%;";
    }

    private static string GetRegionDisplayName(int index, int zoneCount)
    {
        return zoneCount switch
        {
            1 => "主區塊",
            2 => index == 0 ? "上區塊" : "下區塊",
            _ => index switch
            {
                0 => "上區塊",
                1 => "中區塊",
                _ => "下區塊"
            }
        };
    }

    private string GetStageClass(ScreenOrientation orientation)
    {
        return orientation == ScreenOrientation.Portrait9x16 ? "stage-portrait" : "stage-landscape";
    }

    private string GetCanvasClass(ScreenOrientation orientation)
    {
        return orientation == ScreenOrientation.Portrait9x16 ? "canvas-portrait" : "canvas-landscape";
    }

    private string GetMediaIcon(string mediaType)
    {
        return mediaType switch
        {
            "Video" => Icons.Material.Filled.Movie,
            "Image" => Icons.Material.Filled.Image,
            "Text" => Icons.Material.Filled.TextSnippet,
            _ => Icons.Material.Filled.Attachment
        };
    }

    private async Task RunBusyActionAsync(string message, Func<Task> action, string successMessage)
    {
        if (_isBusy)
            return;

        _isBusy = true;
        _busyMessage = message;
        StateHasChanged();

        try
        {
            await action();
            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"操作失敗：{ex.Message}", Severity.Error);
        }
        finally
        {
            _isBusy = false;
            _busyMessage = "";
            StateHasChanged();
        }
    }

    private sealed record LayoutPreset(string Label, double[] Ratios);
}
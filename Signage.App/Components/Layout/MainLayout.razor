@inherits LayoutComponentBase
@using MudBlazor
@using MudBlazor.Services
@inject NavigationManager NavigationManager
@inject AuthSessionService AuthSession
@inject ISnackbar Snackbar
@rendermode InteractiveServer
@implements IDisposable

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout @onmousemove="OnUserActivity" @onkeydown="OnUserActivity" @onclick="OnUserActivity">
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h5" Class="mr-auto">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
            觀光局電子看板管理系統
        </MudText>
        @if (AuthSession.IsAuthenticated)
        {
            <MudChip T="string" Text="@($"{AuthSession.DisplayName} ({AuthSession.Role})")" Variant="Variant.Outlined" Color="Color.Warning" Class="mr-2" />
            <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="Logout">登出</MudButton>
        }
        <MudChip T="string" Text="版本 1.0" Variant="Variant.Text" Color="Color.Info" Icon="@Icons.Material.Filled.Info" />
    </MudAppBar>

    <MudDrawer Open="true" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavGroup Title="管理功能" Icon="@Icons.Material.Filled.Dashboard" Expanded="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Settings" Text="版型配置" Href="/" />
                <MudListItem T="string" Icon="@Icons.Material.Filled.PhotoLibrary" Text="媒體庫" Href="/media" />
                <MudListItem T="string" Icon="@Icons.Material.Filled.Devices" Text="設備管理" Href="/devices" />
                <MudListItem T="string" Icon="@Icons.Material.Filled.AdminPanelSettings" Text="帳號管理" Href="/users" />
                <MudListItem T="string" Icon="@Icons.Material.Filled.FactCheck" Text="操作稽核" Href="/audit-logs" />
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-16 pt-16">
            <CascadingValue Value="string.Empty">
                @Body
            </CascadingValue>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    protected override void OnInitialized()
    {
        AuthSession.OnIdleLogout += HandleIdleLogout;
    }

    private void OnUserActivity()
    {
        AuthSession.RecordActivity();
    }

    private void HandleIdleLogout()
    {
        InvokeAsync(async () =>
        {
            await AuthSession.LogoutAsync();
            Snackbar.Add("閒置超過 15 分鐘，已自動登出", Severity.Warning);
            NavigationManager.NavigateTo("/login", forceLoad: true);
        });
    }

    private async Task Logout()
    {
        await AuthSession.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthSession.OnIdleLogout -= HandleIdleLogout;
    }
}
